{
  "manifest_version": 3,
  "name": "Claude Export Hub",
  "version": "2.0",
  "description": "Export Claude chats, transcripts, artifacts, and pasted content as organized ZIP archives",
  "permissions": [
    "tabs",
    "downloads",
    "storage",
    "webRequest",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://api.claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "run_at": "document_end",
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "banner.js",
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Export Hub",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
